# Optional. If omitted, the web app uses same-origin relative API routes (recommended).
# Set this only when web and api are hosted on different origins.
NEXT_PUBLIC_API_BASE_URL=
# Optional. Controls the absolute share/permalink domain used by admin share entry points.
# Defaults to https://xuanyuku.cn when omitted.
NEXT_PUBLIC_PUBLIC_APP_ORIGIN=
NEXT_PUBLIC_SUPER_ADMIN_ENABLED=false
NEXT_PUBLIC_ADMIN_APP_ORIGIN=http://localhost:30020
