# Optional. If omitted, the web app uses same-origin relative API routes (recommended).
# Set this only when web and api are hosted on different origins.
NEXT_PUBLIC_API_BASE_URL=
# Optional. Controls the absolute share/permalink domain used by admin share entry points.
# If omitted, it auto-uses the current page origin.
NEXT_PUBLIC_PUBLIC_APP_ORIGIN=
# Optional. Public image asset domain (CDN). Example: https://img.example.com
# If omitted, public pages load assets from current origin.
NEXT_PUBLIC_PUBLIC_ASSET_BASE_URL=
# Optional. Server-side cache TTL (seconds) for public share data API.
# Lower for fresher data, higher for faster back/forward navigation.
PUBLIC_SHARE_WEB_REVALIDATE_SECONDS=45
NEXT_PUBLIC_SUPER_ADMIN_ENABLED=false
NEXT_PUBLIC_ADMIN_APP_ORIGIN=http://localhost:30020
