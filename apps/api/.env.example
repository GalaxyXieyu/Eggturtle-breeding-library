PORT=30011
NODE_ENV=development
DATABASE_URL=postgres://eggturtle:eggturtle@localhost:30001/eggturtle
JWT_SECRET=replace-with-dev-only-secret
JWT_EXPIRES_IN_SECONDS=604800
AUTH_CODE_TTL_MINUTES=10
AUTH_CODE_PEPPER=
AUTH_SECURITY_PEPPER=
AUTH_DEV_CODE_ENABLED=false
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_TEMPLATE_PARAM_CODE_KEY=code
ALIYUN_SMS_TEMPLATE_PARAM_MIN_KEY=min
ALIYUN_SMS_COUNTRY_CODE=86
ALIYUN_SMS_REGION_ID=cn-hangzhou
ALIYUN_SMS_ENDPOINT=dypnsapi.aliyuncs.com
ALIYUN_SMS_DUPLICATE_POLICY=1
ALIYUN_SMS_INTERVAL_SECONDS=60
ALIYUN_SMS_AUTO_RETRY=1
ALIYUN_SMS_SCHEME_NAME=
# Super-admin access is managed in the database (`users.is_super_admin`).
# Local dev seed bootstraps `admin / Siri@2026`.
# Production should use:
# `pnpm --filter @eggturtle/api super-admin:bootstrap -- --account admin --email admin@example.com --password '<temporary-password>' --confirm`
# Additional grants use:
# `pnpm --filter @eggturtle/api super-admin:set -- --login <account|phone|email> --confirm`
WEB_DEV_ORIGIN=http://localhost:30010,http://localhost:30020
STORAGE_PROVIDER=local
S3_ENDPOINT=http://127.0.0.1:30002
S3_REGION=us-east-1
S3_BUCKET=eggturtle
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123456
S3_FORCE_PATH_STYLE=true
UPLOAD_DIR=./.data/uploads
UPLOAD_PUBLIC_ENABLED=false
UPLOAD_PUBLIC_BASE_URL=/uploads
# Optional. If omitted, API share entry links use current request origin.
API_PUBLIC_BASE_URL=http://localhost:30011
# Optional. If omitted, /s/:shareToken redirects use current request origin.
WEB_PUBLIC_BASE_URL=http://localhost:30010
PUBLIC_SHARE_SIGNING_SECRET=replace-with-dev-only-share-secret
PUBLIC_SHARE_SIGNED_URL_TTL_SECONDS=86400
PUBLIC_SHARE_ENTRY_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_SHARE_ENTRY_RATE_LIMIT_MAX=20

# Payment scaffold (default disabled)
PAYMENT_FEATURE_ENABLED=false

PAYMENT_ALIPAY_ENABLED=false
PAYMENT_ALIPAY_APP_ID=
PAYMENT_ALIPAY_PRIVATE_KEY=
PAYMENT_ALIPAY_PUBLIC_KEY=
PAYMENT_ALIPAY_NOTIFY_URL=
PAYMENT_ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

PAYMENT_WECHAT_ENABLED=false
PAYMENT_WECHAT_MCH_ID=
PAYMENT_WECHAT_APP_ID=
PAYMENT_WECHAT_API_V3_KEY=
PAYMENT_WECHAT_MCH_SERIAL_NO=
PAYMENT_WECHAT_PRIVATE_KEY_PATH=
PAYMENT_WECHAT_PLATFORM_SERIAL_NO=
PAYMENT_WECHAT_PLATFORM_CERT_PATH=
PAYMENT_WECHAT_PLATFORM_PUBLIC_KEY_PATH=
WECHAT_MP_APP_SECRET=
PAYMENT_WECHAT_NOTIFY_URL=

REFERRAL_REWARD_MODE=FIRST_PRODUCT_CREATE
REFERRAL_FIRST_PRODUCT_REFERRER_DAYS=7
REFERRAL_FIRST_PRODUCT_INVITEE_DAYS=7
REFERRAL_ATTRIBUTION_TTL_DAYS=30
REFERRAL_AUTO_BIND_PUBLIC_ENABLED=true
PUBLIC_VERIFY_BASE_URL=http://localhost:30010
