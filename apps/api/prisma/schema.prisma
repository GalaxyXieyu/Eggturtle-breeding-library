generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantMemberRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum TenantSubscriptionPlan {
  FREE
  BASIC
  PRO
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique @db.VarChar(255)
  account             String?              @unique @db.VarChar(32)
  name                String?              @db.VarChar(120)
  passwordHash        String?              @map("password_hash") @db.VarChar(255)
  passwordUpdatedAt   DateTime?            @map("password_updated_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  securityProfile     UserSecurityProfile?
  phoneBinding        UserPhoneBinding?
  tenantMembers       TenantMember[]
  createdSubscriptionActivationCodes SubscriptionActivationCode[] @relation("SubscriptionActivationCodeCreator")
  auditLogs           AuditLog[]           @relation("AuditLogActor")
  createdShares       PublicShare[]        @relation("PublicShareCreator")
  issuedProductCertificates ProductCertificate[] @relation("ProductCertificateIssuer")
  generatedProductCouplePhotos ProductCouplePhoto[] @relation("ProductCouplePhotoGenerator")
  superAdminAuditLogs SuperAdminAuditLog[] @relation("SuperAdminAuditLogActor")

  @@map("users")
}

model UserSecurityProfile {
  id         String   @id @default(cuid())
  userId     String   @unique @map("user_id")
  question   String   @db.VarChar(120)
  answerHash String   @map("answer_hash") @db.VarChar(128)
  salt       String   @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_security_profiles")
}

model UserPhoneBinding {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  phoneNumber String   @unique @map("phone_number") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneNumber], map: "user_phone_bindings_phone_number_idx")
  @@map("user_phone_bindings")
}

model AuthCode {
  id         String    @id @default(cuid())
  email      String    @db.VarChar(255)
  codeHash   String    @map("code_hash") @db.VarChar(128)
  salt       String    @db.VarChar(64)
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([email], map: "auth_codes_email_idx")
  @@index([email, createdAt], map: "auth_codes_email_created_at_idx")
  @@map("auth_codes")
}

model Tenant {
  id                  String               @id @default(cuid())
  slug                String               @unique @db.VarChar(80)
  name                String               @db.VarChar(120)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  members             TenantMember[]
  products            Product[]
  series              Series[]
  productEvents       ProductEvent[]
  featuredProducts    FeaturedProduct[]
  shares              PublicShare[]
  sharePresentationConfig TenantSharePresentationConfig?
  productCertificates ProductCertificate[]
  certificateQuotaMonthly TenantCertificateQuotaMonthly[]
  productCouplePhotos ProductCouplePhoto[]
  saleBatches         SaleBatch[]
  saleAllocations     SaleAllocation[]
  saleSubjectMedia    SaleSubjectMedia[]
  auditLogs           AuditLog[]
  targetedSubscriptionActivationCodes SubscriptionActivationCode[] @relation("SubscriptionActivationCodeTargetTenant")
  superAdminAuditLogs SuperAdminAuditLog[] @relation("SuperAdminAuditLogTenant")
  subscription        TenantSubscription?

  @@map("tenants")
}

model TenantSubscription {
  id              String                 @id @default(cuid())
  tenantId        String                 @unique @map("tenant_id")
  plan            TenantSubscriptionPlan @default(FREE)
  startsAt        DateTime               @default(now()) @map("starts_at")
  expiresAt       DateTime?              @map("expires_at")
  disabledAt      DateTime?              @map("disabled_at")
  disabledReason  String?                @map("disabled_reason") @db.VarChar(255)
  maxImages       Int?                   @map("max_images")
  maxStorageBytes BigInt?                @map("max_storage_bytes")
  maxShares       Int?                   @map("max_shares")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([plan], map: "tenant_subscriptions_plan_idx")
  @@map("tenant_subscriptions")
}

model SubscriptionActivationCode {
  id              String                 @id @default(cuid())
  codeDigest      String                 @unique @map("code_digest") @db.VarChar(128)
  codeLabel       String                 @map("code_label") @db.VarChar(32)
  targetTenantId  String?                @map("target_tenant_id")
  plan            TenantSubscriptionPlan @default(PRO)
  durationDays    Int?                   @map("duration_days")
  maxImages       Int?                   @map("max_images")
  maxStorageBytes BigInt?                @map("max_storage_bytes")
  maxShares       Int?                   @map("max_shares")
  redeemLimit     Int                    @default(1) @map("redeem_limit")
  redeemedCount   Int                    @default(0) @map("redeemed_count")
  expiresAt       DateTime?              @map("expires_at")
  disabledAt      DateTime?              @map("disabled_at")
  createdByUserId String                 @map("created_by_user_id")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  createdByUser   User                   @relation("SubscriptionActivationCodeCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  targetTenant    Tenant?                @relation("SubscriptionActivationCodeTargetTenant", fields: [targetTenantId], references: [id], onDelete: SetNull)

  @@index([targetTenantId], map: "subscription_activation_codes_target_tenant_id_idx")
  @@index([createdByUserId], map: "subscription_activation_codes_created_by_user_id_idx")
  @@index([expiresAt], map: "subscription_activation_codes_expires_at_idx")
  @@index([plan], map: "subscription_activation_codes_plan_idx")
  @@map("subscription_activation_codes")
}

model TenantMember {
  id        String           @id @default(cuid())
  tenantId  String           @map("tenant_id")
  userId    String           @map("user_id")
  role      TenantMemberRole @default(VIEWER)
  createdAt DateTime         @default(now()) @map("created_at")
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId], map: "tenant_members_tenant_id_user_id_key")
  @@unique([userId], map: "tenant_members_user_id_key")
  @@index([tenantId], map: "tenant_members_tenant_id_idx")
  @@map("tenant_members")
}

model Product {
  id                  String            @id @default(cuid())
  tenantId            String            @map("tenant_id")
  seriesId            String?           @map("series_id")
  legacyBreederId     String?           @map("legacy_breeder_id")
  code                String            @db.VarChar(120)
  type                String            @default("breeder") @db.VarChar(80)
  name                String?           @db.VarChar(120)
  description         String?
  sex                 String?           @db.VarChar(20)
  offspringUnitPrice  Decimal?          @map("offspring_unit_price") @db.Decimal(10, 2)
  sireCode            String?           @map("sire_code") @db.VarChar(120)
  damCode             String?           @map("dam_code") @db.VarChar(120)
  mateCode            String?           @map("mate_code") @db.VarChar(120)
  excludeFromBreeding Boolean           @default(false) @map("exclude_from_breeding")
  hasSample           Boolean           @default(false) @map("has_sample")
  inStock             Boolean           @default(true) @map("in_stock")
  popularityScore     Int               @default(0) @map("popularity_score")
  // Legacy parity flag; FeaturedProduct relation still drives curated ordering/public display.
  isFeatured          Boolean           @default(false) @map("is_featured")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  series              Series?           @relation(fields: [seriesId, tenantId], references: [id, tenantId], onDelete: Restrict)
  images              ProductImage[]
  events              ProductEvent[]
  featuredProducts    FeaturedProduct[]
  shares              PublicShare[]
  certificates        ProductCertificate[]
  couplePhotos        ProductCouplePhoto[] @relation("ProductCouplePhotoFemale")
  saleBatches         SaleBatch[]
  saleSubjectMedia    SaleSubjectMedia[]

  // Enables composite foreign keys to enforce tenant isolation.
  @@unique([id, tenantId], map: "products_id_tenant_id_key")
  @@unique([tenantId, code], map: "products_tenant_id_code_key")
  @@unique([tenantId, legacyBreederId], map: "products_tenant_id_legacy_breeder_id_key")
  @@index([tenantId], map: "products_tenant_id_idx")
  @@index([tenantId, seriesId], map: "products_tenant_id_series_id_idx")
  @@index([tenantId, sex], map: "products_tenant_id_sex_idx")
  @@index([tenantId, type], map: "products_tenant_id_type_idx")
  @@map("products")
}

model ProductCertificate {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  productId       String   @map("product_id")
  eggEventId      String?  @map("egg_event_id")
  saleBatchId     String?  @map("sale_batch_id")
  saleAllocationId String? @map("sale_allocation_id")
  subjectMediaId  String?  @map("subject_media_id")
  previousCertificateId String? @map("previous_certificate_id")
  versionNo       Int      @default(1) @map("version_no")
  voidReason      String?  @map("void_reason") @db.VarChar(240)
  certNo          String   @map("cert_no") @db.VarChar(120)
  verifyId        String   @unique @map("verify_id") @db.VarChar(40)
  status          String   @default("ISSUED") @db.VarChar(40)
  templateVersion String   @map("template_version") @db.VarChar(40)
  lineageSnapshot Json     @map("lineage_snapshot")
  saleSnapshot    Json?    @map("sale_snapshot")
  watermarkSnapshot Json?  @map("watermark_snapshot")
  imageKey        String   @map("image_key") @db.VarChar(500)
  imageUrl        String   @map("image_url") @db.VarChar(1000)
  contentType     String?  @map("content_type") @db.VarChar(255)
  sizeBytes       BigInt   @default(0) @map("size_bytes")
  issuedAt        DateTime @default(now()) @map("issued_at")
  issuedByUserId  String   @map("issued_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId, tenantId], references: [id, tenantId], onDelete: Cascade)
  eggEvent        ProductEvent? @relation("ProductCertificateEggEvent", fields: [eggEventId, tenantId], references: [id, tenantId], onDelete: Restrict)
  saleBatch       SaleBatch? @relation(fields: [saleBatchId, tenantId], references: [id, tenantId], onDelete: Restrict)
  saleAllocation  SaleAllocation? @relation(fields: [saleAllocationId, tenantId], references: [id, tenantId], onDelete: Restrict)
  subjectMedia    SaleSubjectMedia? @relation(fields: [subjectMediaId, tenantId], references: [id, tenantId], onDelete: Restrict)
  previousCertificate ProductCertificate? @relation("ProductCertificateVersionChain", fields: [previousCertificateId], references: [id], onDelete: SetNull)
  nextCertificates ProductCertificate[] @relation("ProductCertificateVersionChain")
  issuedByUser    User     @relation("ProductCertificateIssuer", fields: [issuedByUserId], references: [id], onDelete: Cascade)

  @@unique([tenantId, certNo], map: "product_certificates_tenant_id_cert_no_key")
  @@index([tenantId], map: "product_certificates_tenant_id_idx")
  @@index([tenantId, productId], map: "product_certificates_tenant_id_product_id_idx")
  @@index([tenantId, eggEventId], map: "product_certificates_tenant_id_egg_event_id_idx")
  @@index([tenantId, saleBatchId], map: "product_certificates_tenant_id_sale_batch_id_idx")
  @@index([tenantId, saleAllocationId], map: "product_certificates_tenant_id_sale_allocation_id_idx")
  @@index([tenantId, issuedAt], map: "product_certificates_tenant_id_issued_at_idx")
  @@index([issuedByUserId], map: "product_certificates_issued_by_user_id_idx")
  @@map("product_certificates")
}

model TenantCertificateQuotaMonthly {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  monthKey  String   @map("month_key") @db.VarChar(6)
  usedCount Int      @default(0) @map("used_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, monthKey], map: "tenant_certificate_quota_monthly_tenant_id_month_key_key")
  @@index([tenantId], map: "tenant_certificate_quota_monthly_tenant_id_idx")
  @@map("tenant_certificate_quota_monthly")
}

model ProductCouplePhoto {
  id                    String    @id @default(cuid())
  tenantId              String    @map("tenant_id")
  femaleProductId       String    @map("female_product_id")
  maleProductIdSnapshot String?   @map("male_product_id_snapshot")
  femaleCodeSnapshot    String    @map("female_code_snapshot") @db.VarChar(120)
  maleCodeSnapshot      String    @map("male_code_snapshot") @db.VarChar(120)
  femaleImageKeySnapshot String?  @map("female_image_key_snapshot") @db.VarChar(500)
  maleImageKeySnapshot  String?   @map("male_image_key_snapshot") @db.VarChar(500)
  priceSnapshot         Decimal?  @map("price_snapshot") @db.Decimal(10, 2)
  templateVersion       String    @map("template_version") @db.VarChar(40)
  watermarkSnapshot     Json?     @map("watermark_snapshot")
  imageKey              String    @map("image_key") @db.VarChar(500)
  imageUrl              String    @map("image_url") @db.VarChar(1000)
  contentType           String?   @map("content_type") @db.VarChar(255)
  sizeBytes             BigInt    @default(0) @map("size_bytes")
  isCurrent             Boolean   @default(true) @map("is_current")
  staleReason           String?   @map("stale_reason") @db.VarChar(80)
  generatedAt           DateTime  @default(now()) @map("generated_at")
  generatedByUserId     String    @map("generated_by_user_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  femaleProduct         Product   @relation("ProductCouplePhotoFemale", fields: [femaleProductId, tenantId], references: [id, tenantId], onDelete: Cascade)
  generatedByUser       User      @relation("ProductCouplePhotoGenerator", fields: [generatedByUserId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "product_couple_photos_tenant_id_idx")
  @@index([tenantId, femaleProductId], map: "product_couple_photos_tenant_id_female_product_id_idx")
  @@index([tenantId, femaleProductId, isCurrent], map: "product_couple_photos_tenant_female_current_idx")
  @@index([generatedByUserId], map: "product_couple_photos_generated_by_user_id_idx")
  @@map("product_couple_photos")
}

model Series {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  code        String    @db.VarChar(120)
  name        String    @db.VarChar(120)
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]

  // Enables composite foreign keys to enforce tenant isolation.
  @@unique([id, tenantId], map: "series_id_tenant_id_key")
  @@unique([tenantId, code], map: "series_tenant_id_code_key")
  @@index([tenantId], map: "series_tenant_id_idx")
  @@index([tenantId, sortOrder], map: "series_tenant_id_sort_order_idx")
  @@map("series")
}

model ProductEvent {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  productId    String   @map("product_id")
  eventType    String   @map("event_type") @db.VarChar(40)
  eventDate    DateTime @map("event_date")
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId, tenantId], references: [id, tenantId], onDelete: Cascade)
  saleBatches  SaleBatch[]
  certificates ProductCertificate[] @relation("ProductCertificateEggEvent")

  @@unique([id, tenantId], map: "product_events_id_tenant_id_key")
  @@index([tenantId], map: "product_events_tenant_id_idx")
  @@index([tenantId, productId], map: "product_events_tenant_id_product_id_idx")
  @@index([tenantId, productId, eventDate], map: "product_events_tenant_id_product_id_event_date_idx")
  @@map("product_events")
}

model SaleBatch {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  femaleProductId     String   @map("female_product_id")
  eggEventId          String   @map("egg_event_id")
  batchNo             String   @map("batch_no") @db.VarChar(120)
  status              String   @default("OPEN") @db.VarChar(40)
  plannedQuantity     Int      @default(1) @map("planned_quantity")
  soldQuantity        Int      @default(0) @map("sold_quantity")
  eventDateSnapshot   DateTime @map("event_date_snapshot")
  eggCountSnapshot    Int?     @map("egg_count_snapshot")
  femaleCodeSnapshot  String   @map("female_code_snapshot") @db.VarChar(120)
  sireCodeSnapshot    String   @map("sire_code_snapshot") @db.VarChar(120)
  seriesNameSnapshot  String?  @map("series_name_snapshot") @db.VarChar(120)
  priceLow            Decimal? @map("price_low") @db.Decimal(10, 2)
  priceHigh           Decimal? @map("price_high") @db.Decimal(10, 2)
  note                String?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  femaleProduct       Product  @relation(fields: [femaleProductId, tenantId], references: [id, tenantId], onDelete: Cascade)
  eggEvent            ProductEvent @relation(fields: [eggEventId, tenantId], references: [id, tenantId], onDelete: Cascade)
  allocations         SaleAllocation[]
  subjectMedia        SaleSubjectMedia[]
  certificates        ProductCertificate[]

  @@unique([id, tenantId], map: "sale_batches_id_tenant_id_key")
  @@unique([tenantId, batchNo], map: "sale_batches_tenant_id_batch_no_key")
  @@index([tenantId], map: "sale_batches_tenant_id_idx")
  @@index([tenantId, femaleProductId], map: "sale_batches_tenant_id_female_product_id_idx")
  @@index([tenantId, eggEventId], map: "sale_batches_tenant_id_egg_event_id_idx")
  @@index([tenantId, status], map: "sale_batches_tenant_id_status_idx")
  @@map("sale_batches")
}

model SaleAllocation {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  saleBatchId      String   @map("sale_batch_id")
  allocationNo     String   @map("allocation_no") @db.VarChar(120)
  status           String   @default("SOLD") @db.VarChar(40)
  quantity         Int      @default(1)
  buyerName        String   @map("buyer_name") @db.VarChar(120)
  buyerAccountId   String?  @map("buyer_account_id") @db.VarChar(120)
  buyerContact     String?  @map("buyer_contact") @db.VarChar(120)
  unitPrice        Decimal? @map("unit_price") @db.Decimal(10, 2)
  channel          String?  @db.VarChar(80)
  campaignId       String?  @map("campaign_id") @db.VarChar(120)
  note             String?
  soldAt           DateTime @default(now()) @map("sold_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleBatch        SaleBatch @relation(fields: [saleBatchId, tenantId], references: [id, tenantId], onDelete: Cascade)
  certificates     ProductCertificate[]

  @@unique([id, tenantId], map: "sale_allocations_id_tenant_id_key")
  @@unique([tenantId, allocationNo], map: "sale_allocations_tenant_id_allocation_no_key")
  @@index([tenantId], map: "sale_allocations_tenant_id_idx")
  @@index([tenantId, saleBatchId], map: "sale_allocations_tenant_id_sale_batch_id_idx")
  @@index([tenantId, status], map: "sale_allocations_tenant_id_status_idx")
  @@index([tenantId, soldAt], map: "sale_allocations_tenant_id_sold_at_idx")
  @@map("sale_allocations")
}

model SaleSubjectMedia {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  femaleProductId  String   @map("female_product_id")
  saleBatchId      String   @map("sale_batch_id")
  label            String?  @db.VarChar(120)
  imageKey         String   @map("image_key") @db.VarChar(500)
  imageUrl         String   @map("image_url") @db.VarChar(1000)
  contentType      String?  @map("content_type") @db.VarChar(255)
  sizeBytes        BigInt   @default(0) @map("size_bytes")
  isPrimary        Boolean  @default(false) @map("is_primary")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  femaleProduct    Product  @relation(fields: [femaleProductId, tenantId], references: [id, tenantId], onDelete: Cascade)
  saleBatch        SaleBatch @relation(fields: [saleBatchId, tenantId], references: [id, tenantId], onDelete: Cascade)
  certificates     ProductCertificate[]

  @@unique([id, tenantId], map: "sale_subject_media_id_tenant_id_key")
  @@index([tenantId], map: "sale_subject_media_tenant_id_idx")
  @@index([tenantId, femaleProductId], map: "sale_subject_media_tenant_id_female_product_id_idx")
  @@index([tenantId, saleBatchId], map: "sale_subject_media_tenant_id_sale_batch_id_idx")
  @@index([tenantId, saleBatchId, isPrimary], map: "sale_subject_media_tenant_batch_primary_idx")
  @@map("sale_subject_media")
}

model FeaturedProduct {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  productId String   @map("product_id")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([tenantId, productId], map: "featured_products_tenant_id_product_id_key")
  @@index([tenantId], map: "featured_products_tenant_id_idx")
  @@index([tenantId, sortOrder], map: "featured_products_tenant_id_sort_order_idx")
  @@map("featured_products")
}

model ProductImage {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  productId   String   @map("product_id")
  key         String   @db.VarChar(500)
  url         String   @db.VarChar(1000)
  contentType String?  @map("content_type") @db.VarChar(255)
  sizeBytes   BigInt   @default(0) @map("size_bytes")
  sortOrder   Int      @default(0) @map("sort_order")
  isMain      Boolean  @default(false) @map("is_main")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  product     Product  @relation(fields: [productId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@index([tenantId], map: "product_images_tenant_id_idx")
  @@index([productId], map: "product_images_product_id_idx")
  @@index([productId, sortOrder], map: "product_images_product_id_sort_order_idx")
  @@map("product_images")
}

model PublicShare {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  resourceType    String   @map("resource_type") @db.VarChar(40)
  resourceId      String   @map("resource_id")
  productId       String?  @map("product_id")
  presentationOverride Json? @map("presentation_override")
  shareToken      String   @unique @map("share_token") @db.VarChar(120)
  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product       Product? @relation(fields: [productId, tenantId], references: [id, tenantId], onDelete: Cascade)
  createdByUser User     @relation("PublicShareCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@unique([tenantId, resourceType, resourceId], map: "public_shares_tenant_id_resource_type_resource_id_key")
  @@unique([tenantId, productId], map: "public_shares_tenant_id_product_id_key")
  @@index([tenantId], map: "public_shares_tenant_id_idx")
  @@index([tenantId, resourceType], map: "public_shares_tenant_id_resource_type_idx")
  @@index([productId], map: "public_shares_product_id_idx")
  @@index([createdByUserId], map: "public_shares_created_by_user_id_idx")
  @@map("public_shares")
}

model TenantSharePresentationConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique @map("tenant_id")
  feedTitle       String?  @map("feed_title") @db.VarChar(120)
  feedSubtitle    String?  @map("feed_subtitle") @db.VarChar(240)
  brandPrimary    String?  @map("brand_primary") @db.VarChar(20)
  brandSecondary  String?  @map("brand_secondary") @db.VarChar(20)
  heroImages      Json?    @map("hero_images")
  showWechatBlock Boolean  @default(false) @map("show_wechat_block")
  wechatQrImageUrl String? @map("wechat_qr_image_url") @db.VarChar(1000)
  wechatId        String?  @map("wechat_id") @db.VarChar(64)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "tenant_share_presentation_configs_tenant_id_idx")
  @@map("tenant_share_presentation_configs")
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  actorUserId  String   @map("actor_user_id")
  action       String   @db.VarChar(120)
  resourceType String   @map("resource_type") @db.VarChar(120)
  resourceId   String?  @map("resource_id") @db.VarChar(120)
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser    User     @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "audit_logs_tenant_id_idx")
  @@index([tenantId, createdAt], map: "audit_logs_tenant_id_created_at_idx")
  @@index([actorUserId], map: "audit_logs_actor_user_id_idx")
  @@map("audit_logs")
}

model SuperAdminAuditLog {
  id             String   @id @default(cuid())
  actorUserId    String   @map("actor_user_id")
  targetTenantId String?  @map("target_tenant_id")
